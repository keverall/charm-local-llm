OLLAMA_BIN="ollama"
OLLAMA_HOST="[::]:11434"
OLLAMA_PORT="11434"
OLLAMA_NUM_PARALLEL="24"         # Single RTX 4090: high concurrency, keep within 24GB VRAM budget
OLLAMA_MAX_LOADED_MODELS="2"     # Keep DevOps + Quick resident (no reload thrash)
OLLAMA_KV_CACHE_TYPE="q4_0"
OLLAMA_GPU_LAYERS="50"           # Full offload to the single RTX 4090
DEFAULT_MODELS="qwen3-coder:30b-gpu,nomic-embed-text:latest"
DEVOPS_MODEL="gemma4:26b-devops"
QUICK_MODEL="devstral-small-2-gpu"
OLLAMA_MODELS="/home/ollama/models"
QDRANT_PORT="6333"
QDRANT_GRPC_PORT="6334"
