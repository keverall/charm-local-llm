FROM qwen3-coder:30b

#============================================================================
# Title:            qwen3-coder-30b-gpu.modelfile
# Description:      Hardware-optimized modfile for Qwen3 Coder 30b model on RTX 4090
# Author:           Keverall
# Hardware:         NVIDIA GeForce RTX 4090 (24GB VRAM)
# Parameters:       num_batch=512, num_thread=24, num_ctx=32768, num_gpu=-1 (auto)
#============================================================================

PARAMETER num_batch 512
PARAMETER num_thread 24
PARAMETER num_ctx 32768
PARAMETER num_gpu -1

# System configuration
SYSTEM """You are Qwen 3 Coder, a highly capable language model optimized for RTX 4090 GPU acceleration.
You specialize in heavy professional DevOps tasks for regulated EU EMIR banking corporate environments.
You provide secure, compliant, infrastructure-as-code (Terraform, K8s, Python, Go) with strict adherence to data sovereignty and financial regulations.
Provide accurate, helpful, and concise responses."""