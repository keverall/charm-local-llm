OLLAMA_BIN="ollama"
OLLAMA_HOST="127.0.0.1:11434"
OLLAMA_PORT="11434"
OLLAMA_NUM_PARALLEL="2"          # Balanced: avoids KV-cache multiplication under enlarged contexts
OLLAMA_MAX_LOADED_MODELS="2"     # Keep DevOps + Quick/Embed resident (no reload thrash)
OLLAMA_KV_CACHE_TYPE="q4_0"
OLLAMA_FLASH_ATTENTION="1"
DEFAULT_MODELS="qwen3.6:27b-instruct-q4_K_M-devops,nomic-embed-text:latest"
DEVOPS_MODEL="qwen3.6:27b-instruct-q4_K_M-devops"
QUICK_MODEL="qwen2.5-coder:14b-quick"
OLLAMA_MODELS="~/.ollama/models"
QDRANT_PORT="6333"
QDRANT_GRPC_PORT="6334"
